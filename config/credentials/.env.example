# Copy this file to .env and fill in real values.
# This file is loaded by docker-compose via env_file.
#
# Credential files (OAuth keys, service accounts, tokens) go in this
# directory (config/credentials/). They are mounted into the container
# at /config/credentials/ and referenced via env vars below.

# ============================================================
# Database
# ============================================================
POSTGRES_PASSWORD=changeme

# ============================================================
# API Keys
# The api_key_env field in te.yml / eMAD configs must match
# the variable name here.
# ============================================================
# GOOGLE_API_KEY=your-google-key
# OPENAI_API_KEY=sk-your-key
# ANTHROPIC_API_KEY=your-anthropic-key

# ============================================================
# eMAD Credentials (optional — only if running those eMADs)
# Place credential files in config/credentials/ and set paths below.
# ============================================================
# GOOGLE_WORKSPACE_SERVICE_ACCOUNT=/config/credentials/google-service-account.json
# M365_TOKEN_CACHE=/config/credentials/msal_token_cache.json
# M365_ACCOUNTS=user@example.com

# ============================================================
# Docker (log shipper needs docker socket GID)
# ============================================================
# DOCKER_GID=125
